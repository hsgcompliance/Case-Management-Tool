# Firebase web config (public client identifiers; same project as web/mobile).
# Copy to .env.local. The forms surface uses Firebase Auth only for the staff
# (form-submission access) side; customer token routes need none of this.
VITE_FIREBASE_PROJECT_ID=housing-db-v2
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=housing-db-v2.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=housing-db-v2.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_APPCHECK_KEY=
VITE_USE_EMULATORS=false
