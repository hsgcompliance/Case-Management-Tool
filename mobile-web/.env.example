# Copy to .env.local and fill in values from Firebase console > Project Settings > Your apps

VITE_FIREBASE_PROJECT_ID=housing-db-v2
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=housing-db-v2.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=housing-db-v2.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to use local emulators
VITE_USE_EMULATORS=false
