{
  "firestore": {
    "database": "(default)",
    "location": "us-central1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "src",
        "*.ts",
        "tsconfig*.json"
      ],
      "predeploy": [
        "node scripts/pack-contracts.mjs",
        "node scripts/set-functions-contracts-dep.mjs",
        "npm --prefix \"$RESOURCE_DIR\" install --package-lock-only --ignore-scripts",
        "npm --prefix \"$RESOURCE_DIR\" run lint",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "apphosting": {
    "backendId": "housing-db-v2",
    "rootDir": "./",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "functions"
    ]
  },
  "hosting": [
    {
      "target": "web",
      "source": "web",
      "frameworksBackend": {
        "memory": "512MiB"
      },
      "predeploy": [
        "node scripts/pack-contracts.mjs"
      ],
      "ignore": [
        "firebase.json",
        "**/.*",
        "!**/.npmrc",
        "**/node_modules/**"
      ]
    },
    {
      "target": "mobile",
      "public": "mobile-web/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/assets/**",
          "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
        },
        {
          "source": "/workbox-*.js",
          "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
        },
        {
          "source": "/icon-*.png",
          "headers": [{ "key": "Cache-Control", "value": "public,max-age=86400" }]
        }
      ]
    },
    {
      "target": "forms",
      "public": "forms-web/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/assets/**",
          "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
        }
      ]
    }
  ],
  "emulators": {
    "apphosting": {
      "port": 5000,
      "rootDirectory": "./",
      "startCommand": "npm run dev --prefix web"
    },
    "functions": {
      "port": 5001
    },
    "firestore": {"port": 5002},
    "pubsub": {"port": 5003},
    "auth": { "port": 5005 }, 
    "ui": {
      "enabled": true,
      "port": 5004
    },
    "singleProjectMode": true
  },
  "remoteconfig": {
    "template": "remoteconfig.template.json"
  }
}
